:{$CADDY_CONTAINER_PORT} {
    @public-utils-denied {
        path /utils/pgadmin*
        not remote_ip private_ranges
    }
    @unknown-utils {
        path /utils/*
        not path /utils/pgadmin*
    }

    respond @public-utils-denied "Forbidden" 403
    respond @unknown-utils "Not Found" 404

    # Admin panel — /admin/* → frontend-admin
    handle_path /admin* {
        reverse_proxy http://frontend-admin:3001
    }

    # Nanobot WebSocket — /ws/chat → nanobot
    handle /ws/chat {
        reverse_proxy http://nanobot:{$NANOBOT_CONTAINER_PORT:-8765}
    }

    # User panel — everything else → frontend-user
    handle {
        reverse_proxy http://frontend-user:3000
    }

    # Backend API — проксируется через Next.js rewrites (frontend сам роутит /api)
    # Если нужен прямой доступ:
    # handle /api* {
    #     reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    # }

    handle /utils/pgadmin* {
        reverse_proxy http://pgadmin:{$CONST_PGADMIN_CONTAINER_PORT}
    }

    # Swagger docs и OpenAPI — напрямую через backend
    handle /docs* {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle /openapi.json {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
}
